# Foundry + Windows 365 for Agents runner configuration.
#
# Default (no .env needed): RUNNER_MODE=simulation runs fully offline - it captures
# the CCaaS outcome from the handoff folder and relays a synthesized claim result,
# so you can wire up and demo the end-to-end flow without any Azure access.
#
# Set RUNNER_MODE=live to drive a real Windows 365 for Agents Cloud PC with the
# Azure AI Foundry Computer Use loop. Live mode needs the variables marked (live).

# simulation | live
RUNNER_MODE=simulation

# This runner's backend identity: mcs | foundry (default foundry). In "both" demo mode the
# CCaaS desktop stamps each handoff with the backend the presenter picked (target_backend).
# The runner ONLY acts on prefills addressed to this id (or legacy prefills with no
# target_backend), so the MCS and Foundry agents never both drive the Cloud PC at once.
RUNNER_BACKEND_ID=foundry

# Handoff folder shared with the legacy claims app + local orchestrator. Must be the
# SAME path the local orchestrator writes to (its default is the one below). The
# runner watches in\prefill.json and writes out\ready|result|error.json.
HANDOFF_DIR=C:\ProgramData\ZavaClaims\handoff

# --- Azure AI Foundry (live) -------------------------------------------------
# Resource base for the responses API, no trailing slash:
FOUNDRY_ENDPOINT=https://<your-resource>.openai.azure.com
# Model deployment that has Computer Use (request access: https://aka.ms/oai/cuaaccess):
FOUNDRY_MODEL=computer-use-preview
# Computer Use tool type: computer_use_preview (classic) or computer (newer models).
FOUNDRY_TOOL_TYPE=computer_use_preview
# Optional responses api-version query string (leave as-is unless your endpoint needs it):
FOUNDRY_API_VERSION=preview
# Virtual display the model reasons about - must match the Cloud PC resolution:
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=800
# Hard cap on the screenshot->action loop:
MAX_ITERATIONS=40

# --- Windows 365 for Agents (live) -------------------------------------------
# Session-lifecycle API base (no trailing slash) and the pool to check a Cloud PC out of.
# See docs/agent-cua-setup.md (Optional - enterprise hardening) for enablement.
W365A_BASE_URL=https://<your-w365a-pool-endpoint>
W365A_POOL_ID=<your-pool-id>
W365A_SESSION_API_VERSION=2.0
W365A_MCP_API_VERSION=1.0
# Command used to launch the legacy app on the Cloud PC before the CU loop:
W365A_LAUNCH_COMMAND="%ProgramFiles%\Business Applications\Zava Claims Workstation\claims.exe" --no-splash --fast-auth --stable-host --idle-timeout=0 --demo-pin=1234

# --- Entra auth (live) -------------------------------------------------------
# Leave blank to use DefaultAzureCredential (az login / managed identity). Set all
# three for unattended app-only auth on the Cloud PC.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Token scopes (override only if your tenant differs):
FOUNDRY_SCOPE=https://ai.azure.com/.default
W365A_SCOPE=https://cloudpc.microsoft.com/.default
