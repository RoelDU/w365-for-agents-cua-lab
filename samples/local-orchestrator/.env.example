# Local Orchestrator configuration. All variables are optional; the defaults
# below match the CCaaS Agent Desktop's defaults and the legacy claims app's
# default handoff folder on a Windows 365 Cloud PC.

# Port the orchestrator listens on. The CCaaS desktop defaults to
# http://localhost:4000 (VITE_ORCHESTRATOR_URL).
PORT=4000

# Root of the legacy app's handoff folder. Must be the SAME path the legacy
# claims.exe uses (its default is %ProgramData%\ZavaClaims\handoff). The
# orchestrator writes in\prefill.json and watches out\ for ready/result/error.
# Override the legacy app side with: claims.exe --handoff-dir=<path>
HANDOFF_DIR=C:\ProgramData\ZavaClaims\handoff

# Comma-separated list of allowed CORS origins. Use "*" (default) to reflect
# any origin (fine for a demo-only local tool). Set to an explicit list to
# lock it down, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.azurestaticapps.net
ALLOWED_ORIGINS=*
