# ─── Legacy Claims Workstation (Win32/C, apps/legacy-claims-workstation/) ───
*.exe
*.o
*.obj
*.res
*.zip
*.intunewin
**/data/
**/out/
claims.log

# Exception: prebuilt Intune packages for the in-tenant admin workstation ARE
# tracked, so a build-less admin box can `git pull` and deploy without compiling.
!deploy/intune-packages/*.intunewin

# ─── CCaaS Agent Desktop (React/Vite/TS, apps/ccaas-agent-desktop/) ───
**/node_modules/
**/dist/
**/coverage/
**/.vite/
**/.turbo/
*.tsbuildinfo

# Env files (never commit secrets); .env.example IS committed
**/.env
**/.env.local
**/.env.*.local
!**/.env.example

# Local demo configuration (subscription/tenant IDs + the SWA->Foundry client
# secret used at deploy time). NEVER committed; copy demo-config.sample.json to
# demo-config.local.json and fill it in. The *.sample.json template IS tracked.
**/*.local.json

# ─── Local Orchestrator (samples/local-orchestrator/) ───
**/orchestrator.log

# ─── IDE / OS ───
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
Thumbs.db
.DS_Store

# ─── Logs ───
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Scout read-only Graph credentials (never commit)
.scout.env
