{
  "name": "ccaas-agent-desktop",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "description": "Zava Contact Center — Agent Workspace (CCaaS Agent Desktop demo for the CCaaSDemoApp monorepo).",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prevalidate": "node -e \"const v=process.versions.node.split('.')[0]; if(v>=24){console.warn('⚠️  Node '+process.version+' detected. Recommended: Node 22 LTS (.nvmrc). Build may hang on Node 24 + Windows/OneDrive.')}\"",
    "validate": "npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@azure/msal-browser": "3.27.0",
    "@azure/msal-react": "2.2.0",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-toast": "1.2.2",
    "@radix-ui/react-tooltip": "1.1.4",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0",
    "tailwind-merge": "2.5.4",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "jsdom": "25.0.1",
    "msw": "2.6.4",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "vitest": "2.1.4"
  }
}
