# Zava Contact Center — Agent Workspace
# All variables are optional. Copy this file to .env.local to override defaults
# during local development.
#
# The app uses Microsoft Entra ID (MSAL) as its single sign-in path. Without an
# app-registration client id configured (via the VITE_AZURE_* vars below or a
# served /entra-config.json), the sign-in button reports "not configured yet".

# Entra ID app registration (configures the sole sign-in path). Register an SPA
# app registration in your demo M365 E5 tenant with the redirect URI matching
# the value below. Leave the client id as the all-zero placeholder to keep
# sign-in disabled for a fresh checkout.
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=common
VITE_AZURE_REDIRECT_URI=http://localhost:5173/

# Handoff endpoint base URL. In the standard deployment this is the Azure Static
# Web App's "/api" (e.g. https://<your-swa>.azurestaticapps.net/api), which hosts
# the handoff Function. For an offline/local lab you can instead point this at the
# local orchestrator (samples/local-orchestrator/, default http://localhost:4000).
# The app POSTs the CallContext here and polls (or subscribes via SSE) for status.
VITE_ORCHESTRATOR_URL=http://localhost:4000

# Brand override (rarely needed)
VITE_BUILD_VERSION=3.2.0

# Live in-app agent desktop (optional). When set to the Copilot Studio Direct Line
# token endpoint, the "Transfer to AI Agent" button opens its own Direct Line
# conversation in the browser and streams the live Computer Use desktop + claim id
# straight into the AI Agent Status panel (no orchestrator, no test pane, no typing).
# Leave unset to keep the orchestrator handoff path.
# VITE_DIRECTLINE_TOKEN_URL=https://<env>.environment.api.powerplatform.com/powervirtualagents/botsbyschema/<schema>/directline/token?api-version=2022-03-01-preview
